; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Gravity Bumpers"
config/description="By ghKoty"
config/version="0.8.1"
run/main_scene="uid://k43vbpdmcxxc"
config/quit_on_go_back=false
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="uid://dlk2mpcai6ksa"

[audio]

buses/default_bus_layout="uid://b5r2ow026pi05"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4
window/vsync/vsync_mode=0

[editor]

run/main_run_args="--forcelan"

[file_customization]

folder_colors={
"res://assets/prefabs/": "orange",
"res://assets/resources/": "pink",
"res://assets/scenes/": "blue",
"res://assets/scripts/": "green",
"res://assets/shaders/": "purple",
"res://assets/textures/": "red",
"res://assets/third-party/": "red"
}

